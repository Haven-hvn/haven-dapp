{
  "name": "haven-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true next build --webpack",
    "export": "next build --webpack",
    "build:prod": "next build --webpack",
    "preview": "next start",
    "clean": "rm -rf .next out",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:report": "playwright show-report",
    "test:install": "playwright install --with-deps",
    "test:web3": "cross-env INCLUDE_WEB3_TESTS=true playwright test --project=web3-chromium",
    "test:web3:headed": "cross-env INCLUDE_WEB3_TESTS=true playwright test --project=web3-chromium --headed",
    "test:web3:ui": "cross-env INCLUDE_WEB3_TESTS=true playwright test --project=web3-chromium --ui",
    "test:all": "cross-env INCLUDE_WEB3_TESTS=true playwright test",
    "postinstall": "node scripts/ensure-haven-aol.mjs"
  },
  "dependencies": {
    "@arkiv-network/sdk": "0.6.8",
    "@filoz/synapse-sdk": "0.41.0",
    "@icp-sdk/core": "^5.4.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-slot": "1.2.4",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@reown/appkit": "1.8.19",
    "@reown/appkit-adapter-wagmi": "1.8.19",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-query-devtools": "5.100.10",
    "@wagmi/core": "3.4.12",
    "accounts": "^0.12.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "ethers": "6.16.0",
    "idb": "8.0.3",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "pino-pretty": "13.1.3",
    "porto": "0.2.37",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "viem": "2.49.3",
    "wagmi": "3.6.15",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.60.0",
    "@synthetixio/synpress": "4.1.2",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "eslint": "10.4.0",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "6.2.5",
    "postcss": "8.5.14",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "use-sync-external-store": "1.6.0"
  }
}
